generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id    String @id
  name  String
  type  String @default("KURSUS") // "KURSUS" or "PELATIHAN_KERJA"
}

model Program {
  id                String  @id
  title             String
  short_description String  @db.LongText
  image             String  @db.LongText
  duration          String
  price             Int
  discount_price    Int?
  badge             String?
  category          String
  level             String
  type              String  @default("KURSUS") // "KURSUS" or "PELATIHAN_KERJA"
}

model Certification {
  id                String @id
  title             String
  short_description String @db.LongText
  image             String @db.LongText
  issuing_body      String
  price             Int
}

model Testimonial {
  id          String @id
  name        String
  photo       String @db.LongText
  program     String
  testimonial String @db.LongText
  rating      Int
  job_title   String
  company     String
}

model Post {
  id                String   @id
  title             String
  short_description String   @db.LongText
  image             String   @db.LongText
  published_at      DateTime @default(now())
  type              String   @default("BERITA") // "BERITA" or "ARTIKEL"
}

model AboutData {
  id          Int    @id @default(1)
  title       String
  description String @db.LongText
  image       String @db.LongText
  vision              String  @db.LongText
  mission             String  @db.LongText
  stats               String  @db.LongText
  org_structure_image String? @db.LongText
  logo_philosophy     String? @db.LongText
  logo_usage          String? @db.LongText
}

model HeroSlide {
  id       Int     @id @default(autoincrement())
  title    String
  subtitle String  @db.LongText
  tagline  String?
  image    String  @db.LongText
  type     String?
}

model HeroFeature {
  id    Int    @id @default(autoincrement())
  title String
  icon  String
  link  String
}

model FooterData {
  id          Int    @id @default(1)
  description String @db.LongText
  address     String @db.LongText
  email       String
  phone       String
}

model Partner {
  id          String @id
  name        String
  description String @db.LongText
  icon        String?
  logo        String? @db.LongText
  color       String?
  row         String @default("TOP") // "TOP" or "BOTTOM"
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String   @db.LongText
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}
